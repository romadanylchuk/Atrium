{
  "name": "atrium",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop client for AI-assisted project architecture",
  "author": "Roma",
  "license": "UNLICENSED",
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-pty,@parcel/watcher",
    "rebuild:native": "electron-rebuild -f -w node-pty,@parcel/watcher",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@parcel/watcher": "2.5.6",
    "fix-path": "5.0.0",
    "node-pty": "1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "write-file-atomic": "7.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.3",
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "41.2.1",
    "electron-vite": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
