{
  "name": "atrium",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-session terminal manager for Claude Code",
  "author": "Roma Danylchuk <roma@danylchuk.dev>",
  "homepage": "https://github.com/rdanylchuk/atrium",
  "repository": {
    "type": "git",
    "url": "https://github.com/rdanylchuk/atrium.git"
  },
  "license": "UNLICENSED",
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-pty,@parcel/watcher",
    "rebuild:native": "electron-rebuild -f -w node-pty,@parcel/watcher",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test:e2e": "node scripts/test-e2e.mjs",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@parcel/watcher": "2.5.6",
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "fix-path": "5.0.0",
    "lodash.debounce": "^4.0.8",
    "node-pty": "1.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reactflow": "^11.11.4",
    "write-file-atomic": "7.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.0",
    "@electron/rebuild": "4.0.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "41.2.1",
    "electron-vite": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^29.0.2",
    "png-to-ico": "^2.1.8",
    "png2icons": "^2.0.1",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
